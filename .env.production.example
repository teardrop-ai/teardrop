# Teardrop – Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values marked REQUIRED.
# Variables marked OPTIONAL use safe defaults and can be left unset.
#
# On Render: set these via the Environment tab or via render.yaml.
# Never commit a populated .env file to version control.

# ── [CRITICAL] Application ────────────────────────────────────────────────────

# Runtime environment. Must be "production" in prod.
APP_ENV=production

# Log verbosity. Use "warning" or "error" in prod to reduce noise.
APP_LOG_LEVEL=info

# Host and port (Render sets PORT automatically; leave as-is).
APP_HOST=0.0.0.0
APP_PORT=8000

# ── [CRITICAL] Database ───────────────────────────────────────────────────────

# Neon Postgres connection string (free tier or $20/mo).
# Create at https://console.neon.tech/ and copy the connection string.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/teardrop

# ── [CRITICAL] JWT / Authentication ──────────────────────────────────────────

# RSA-2048 keypair is generated automatically at first startup into keys/.
# The paths below resolve relative to the project root – change only if needed.
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=teardrop

# Client-credentials auth (machine-to-machine).
# On Render: auto-generated via render.yaml generateValue.
JWT_CLIENT_ID=teardrop-client
JWT_CLIENT_SECRET=                          # REQUIRED – strong random string

# ── [CRITICAL] LLM ───────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=                          # REQUIRED – your Anthropic key
AGENT_MODEL=claude-3-5-sonnet-20241022
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0

# ── [RECOMMENDED] CORS ────────────────────────────────────────────────────────

# Restrict to your frontend origin(s). Comma-separated.
# Leave as "*" only for fully public APIs.
CORS_ORIGINS=https://your-frontend.example.com

# ── [RECOMMENDED] SIWE / Web3 ────────────────────────────────────────────────

# Domain used to validate SIWE sign-in messages.
# Must match the domain your frontend runs on (no scheme, no port).
SIWE_DOMAIN=teardrop.onrender.com           # REQUIRED for SIWE auth

SIWE_NONCE_TTL_SECONDS=300

# Ethereum / Base JSON-RPC endpoints (Alchemy, Infura, public nodes, etc.)
ETHEREUM_RPC_URL=                           # RECOMMENDED for ENS + ETH balance tools
BASE_RPC_URL=                               # RECOMMENDED for Base L2 tools

# ── [OPTIONAL] Rate Limiting ──────────────────────────────────────────────────

RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── [OPTIONAL] Tool Providers ────────────────────────────────────────────────

TAVILY_API_KEY=                             # Optional – powers web_search tool

# ── [OPTIONAL] x402 Billing ──────────────────────────────────────────────────

# Set BILLING_ENABLED=true once your wallet and pricing row are configured.
BILLING_ENABLED=false

# Treasury wallet that receives USDC payments.
X402_PAY_TO_ADDRESS=                        # Required when BILLING_ENABLED=true

# Payment scheme: "exact" (flat per-run) or "upto" (usage-based, future).
X402_SCHEME=exact

# Flat price per /agent/run when using the "exact" scheme.
X402_RUN_PRICE=$0.01

# Network: "eip155:84532" = Base Sepolia (testnet), "eip155:8453" = Base (mainnet)
X402_NETWORK=eip155:84532

X402_FACILITATOR_URL=https://x402.org/facilitator

# How long to cache the active pricing_rules row (seconds).
PRICING_CACHE_TTL_SECONDS=300

# ── [OPTIONAL] LangSmith Tracing ─────────────────────────────────────────────

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=teardrop

# ── [OPTIONAL] Tool Registry ─────────────────────────────────────────────────

TOOL_DEPRECATION_WINDOW_DAYS=90
