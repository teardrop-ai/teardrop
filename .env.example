# Teardrop – Development Environment
# =====================================
# Copy this file to .env and fill in the REQUIRED values.
# Never commit a populated .env file to version control.
#
# Legend:
#   [REQUIRED]            — app crashes or core feature is broken without this
#   [REQUIRED IN PROD]    — safe to omit locally but required in production
#   [RECOMMENDED IN PROD] — has a safe default but recommended to set in prod
#   [OPTIONAL]            — has a working default, set only if you need it

# ─── Application ───────────────────────────────────────────────────────────────

APP_ENV=development              # REQUIRED IN PROD: change to "production"
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info               # RECOMMENDED IN PROD: change to "warning"

# ─── Database ─────────────────────────────────────────────────────────────────

# [REQUIRED] Neon Postgres connection string.
# Get from https://console.neon.tech → Connection Details → Connection string (asyncpg).
DATABASE_URL=                    # postgresql://user:password@host/dbname?sslmode=require

# ─── LLM Provider ─────────────────────────────────────────────────────────────

# [REQUIRED] Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=               # sk-ant-...

AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0

# ─── Authentication ────────────────────────────────────────────────────────────

# [REQUIRED IN PROD] Secret for client-credentials (machine-to-machine) JWT auth.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# On Render this is auto-generated via generateValue in render.yaml.
JWT_CLIENT_SECRET=               # strong random string

# ─── CORS ──────────────────────────────────────────────────────────────────────

# [RECOMMENDED IN PROD] Restrict to your frontend origin(s), comma-separated.
# Empty string or "*" both allow all origins (fine for local dev / public APIs
# using bearer-token auth; restrict in production for defense-in-depth).
CORS_ORIGINS=*

# ─── Web3 / SIWE ──────────────────────────────────────────────────────────────

# [RECOMMENDED IN PROD] Domain used to validate SIWE sign-in messages.
# Must match the domain your frontend runs on (no scheme, no trailing slash).
# If unset, defaults to APP_HOST ("0.0.0.0") which will fail SIWE validation in prod.
SIWE_DOMAIN=                     # e.g. teardrop.onrender.com

SIWE_NONCE_TTL_SECONDS=300

# [OPTIONAL] JSON-RPC endpoints — required only for ETH/Base chain tools.
ETHEREUM_RPC_URL=                # Alchemy / Infura / QuickNode mainnet URL
BASE_RPC_URL=                    # Base L2 JSON-RPC URL

# ─── Rate Limiting ─────────────────────────────────────────────────────────────

# [OPTIONAL] Requests per IP per minute. In-memory only (does not persist across restarts).
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ─── Redis (optional) ──────────────────────────────────────────────────────────

# [OPTIONAL] Shared Redis for rate limiting, SIWE nonces, pricing cache.
# Required when running multiple containers. When unset, in-process fallbacks are used.
# Local: redis://localhost:6379
# Render: paste the Internal URL from your Redis dashboard (redis://red-xxxxx:6379)
REDIS_URL=                       # redis://... or rediss://... (with TLS)

# ─── Tool Providers ────────────────────────────────────────────────────────────

# [OPTIONAL] Tavily API key — powers the web_search tool.
# Without it, web_search returns a stub response instead of live results.
TAVILY_API_KEY=                  # tvly-...

# ─── x402 Billing / On-Chain Payments ─────────────────────────────────────────

# [OPTIONAL] Set to "true" once wallet + pricing config is in place.
BILLING_ENABLED=false

# [REQUIRED if BILLING_ENABLED=true] Treasury wallet address that receives USDC.
X402_PAY_TO_ADDRESS=             # 0x... (checksummed EIP-55 address)

# [OPTIONAL] x402 network. Base Sepolia (testnet) by default; use eip155:8453 for mainnet.
X402_NETWORK=eip155:84532

# [OPTIONAL] x402 facilitator URL.
X402_FACILITATOR_URL=https://x402.org/facilitator

# [OPTIONAL] Flat price per /agent/run request (used as fallback if pricing_rules DB table is empty).
X402_RUN_PRICE=$0.01

# ─── USDC On-Chain Credit Top-Up (crypto-native) ──────────────────────────────
# [NOTE] The USDC top-up endpoints (GET /billing/topup/usdc/requirements and
# POST /billing/topup/usdc) share the SAME treasury wallet as x402 billing.
# To enable: set BILLING_ENABLED=true and X402_PAY_TO_ADDRESS above.
# No additional env vars are required for USDC top-up.

# ─── LangSmith Observability ──────────────────────────────────────────────────

# [OPTIONAL] Enable LangSmith tracing for agent runs.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=               # ls__...
LANGSMITH_PROJECT=teardrop