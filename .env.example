# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── LangSmith Observability (optional) ────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=teardrop

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ─── CORS (comma-separated origins; use * for local dev) ───────────────────────
CORS_ORIGINS=*

# ─── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MODEL=claude-3-5-sonnet-20241022
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Tool Providers ──────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here

# ─── Web3 / SIWE ──────────────────────────────────────────────────────────────
# Ethereum mainnet JSON-RPC URL (e.g. Alchemy, Infura, QuickNode)
ETHEREUM_RPC_URL=
# Base L2 JSON-RPC URL
BASE_RPC_URL=
# Expected domain in SIWE messages (leave empty to default to APP_HOST)
SIWE_DOMAIN=

# ─── Postgres / Neon ───────────────────────────────────────────────────────────
# Neon connection string — get from Neon dashboard → Connection Details → asyncpg
# Leave empty to use local SQLite (default for development)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require