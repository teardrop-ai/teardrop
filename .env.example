# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── LangSmith Observability (optional) ────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=teardrop

# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ─── CORS (comma-separated origins; use * for local dev) ───────────────────────
CORS_ORIGINS=*

# ─── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MODEL=claude-3-5-sonnet-20241022
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Tool Providers ──────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Authentication ──────────────────────────────────────────────────────────
JWT_CLIENT_SECRET=your_jwt_client_secret_here

# ─── Web3 / SIWE ──────────────────────────────────────────────────────────────
# Ethereum mainnet JSON-RPC URL (e.g. Alchemy, Infura, QuickNode)
ETHEREUM_RPC_URL=
# Base L2 JSON-RPC URL
BASE_RPC_URL=
# Expected domain in SIWE messages (leave empty to default to APP_HOST)
SIWE_DOMAIN=

# ─── Postgres / Neon ───────────────────────────────────────────────────────────
# Neon connection string — get from Neon dashboard → Connection Details → asyncpg
# Leave empty to use local SQLite (default for development)
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── x402 Billing / On-Chain Payments ──────────────────────────────────────────
# Enable x402 HTTP 402 payment on /agent/run (requires SIWE wallet auth)
BILLING_ENABLED=false
# x402 facilitator URL (https://x402.org/facilitator for public; Coinbase for mainnet)
X402_FACILITATOR_URL=https://x402.org/facilitator
# Treasury wallet address that receives USDC payments (0x-format, checksummed)
X402_PAY_TO_ADDRESS=
# x402 network identifier (eip155:84532 for Base Sepolia dev, eip155:8453 for prod)
X402_NETWORK=eip155:84532
# Flat per-run price in USD (exact scheme; e.g., "$0.01")
X402_RUN_PRICE=$0.01