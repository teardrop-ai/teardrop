# Teardrop – Development Environment
# =====================================
# Copy this file to .env and fill in the REQUIRED values.
# Never commit a populated .env file to version control.
#
# Legend:
#   [REQUIRED]            — app crashes or core feature is broken without this
#   [REQUIRED IN PROD]    — safe to omit locally but required in production
#   [RECOMMENDED IN PROD] — has a safe default but recommended to set in prod
#   [OPTIONAL]            — has a working default, set only if you need it

# ────────────────────────────────────────────────────────────────────────────────
# ─── Application ───────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

APP_ENV=development              # development | production | test. REQUIRED IN PROD.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info               # debug | info | warning | error | critical

# ────────────────────────────────────────────────────────────────────────────────
# ─── Database ──────────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

DATABASE_URL=                    # [REQUIRED] Neon Postgres: postgresql://user:password@host/dbname?sslmode=require

# ────────────────────────────────────────────────────────────────────────────────
# ─── LLM Providers ──────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=               # [REQUIRED] https://console.anthropic.com/
OPENAI_API_KEY=                  # [REQUIRED] https://platform.openai.com/api-keys (also for embeddings)
GOOGLE_API_KEY=                  # [OPTIONAL] Google Generative AI key

AGENT_PROVIDER=anthropic         # anthropic | openai | google
AGENT_MODEL=claude-haiku-4-5-20251001
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0
AGENT_LLM_TIMEOUT_SECONDS=120
AGENT_UI_GENERATOR_TIMEOUT_SECONDS=60
AGENT_MAX_TOOL_ITERATIONS=4           # Max planner→tool cycles before forced synthesis (default: 4)
AGENT_TOOL_MAX_CALLS_PER_RUN={"get_yield_rates":1,"resolve_ens":1}

# ────────────────────────────────────────────────────────────────────────────────
# ─── Authentication & JWT ──────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

JWT_PRIVATE_KEY_PATH=keys/private.pem    # [OPTIONAL] Generated automatically if missing
JWT_PUBLIC_KEY_PATH=keys/public.pem      # [OPTIONAL] Generated automatically if missing
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=teardrop
JWT_CLIENT_ID=teardrop-client
JWT_CLIENT_SECRET=                       # [REQUIRED IN PROD] Generate: python -c "import secrets; print(secrets.token_hex(32))"

REFRESH_TOKEN_EXPIRE_DAYS=30

# ────────────────────────────────────────────────────────────────────────────────
# ─── CORS & Web3 / SIWE ────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

CORS_ORIGINS=*                   # [RECOMMENDED IN PROD] Restrict to frontend domain(s), comma-separated
SIWE_DOMAIN=                     # [RECOMMENDED IN PROD] e.g. api.teardrop.dev (no scheme, no trailing slash)
SIWE_NONCE_TTL_SECONDS=300

ETHEREUM_RPC_URL=                # [OPTIONAL] Alchemy / Infura / QuickNode mainnet URL
BASE_RPC_URL=                    # [OPTIONAL] Base L2 JSON-RPC URL

# ────────────────────────────────────────────────────────────────────────────────
# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

RATE_LIMIT_REQUESTS_PER_MINUTE=60    # In-memory only; for multi-container, use Redis
RATE_LIMIT_AGENT_RPM=30              # Per-user rate limit for /agent/run
RATE_LIMIT_AUTH_RPM=20               # Per-IP rate limit for /token and /auth/siwe/nonce
RATE_LIMIT_REGISTER_RPM=5            # Per-IP rate limit for /register (tighter; registration is rare)
RATE_LIMIT_MCP_RPM=30                # Per-user rate limit for MCP marketplace tool calls

# ────────────────────────────────────────────────────────────────────────────────
# ─── Redis (optional, required for multi-container) ────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

REDIS_URL=                       # [OPTIONAL] redis://... or rediss://... (with TLS)
                                 # Required for multi-container; used for rate limiting, SIWE nonces, pricing cache

# ────────────────────────────────────────────────────────────────────────────────
# ─── Tool Providers ────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

TAVILY_API_KEY=                  # [OPTIONAL] Powers web_search tool; without it, returns stub
COINGECKO_API_KEY=               # [OPTIONAL] Raises rate limits for crypto data
COINGECKO_API_URL=https://api.coingecko.com/api/v3

TOOL_DEPRECATION_WINDOW_DAYS=90  # Days before deprecated tools are removed

# ────────────────────────────────────────────────────────────────────────────────
# ─── Email & Notifications (Resend) ────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=                  # [OPTIONAL] https://resend.com/api-keys
RESEND_FROM_EMAIL=hello@teardrop.dev
APP_BASE_URL=                    # [REQUIRED] Base URL for email links, e.g. https://app.teardrop.dev
REQUIRE_EMAIL_VERIFICATION=false     # [RECOMMENDED: true in production] Block /token (email path) until email is verified

# ────────────────────────────────────────────────────────────────────────────────
# ─── Persistent Memory (per-org RAG with OpenAI embeddings) ────────────────────
# ────────────────────────────────────────────────────────────────────────────────

MEMORY_ENABLED=true              # Auto-disabled if OPENAI_API_KEY is empty
MEMORY_TOP_K=5                   # Number of memories to retrieve per agent run
MEMORY_MAX_PER_ORG=1000          # Max stored memories per organization
MEMORY_TTL_DAYS=0                # Expiry in days (0 = never expire)
MEMORY_CLEANUP_INTERVAL_SECONDS=3600  # Background worker interval for expired memories

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536        # Must match VECTOR(N) in DB schema

# ────────────────────────────────────────────────────────────────────────────────
# ─── Custom Tools (per-org webhook tools) ────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

MAX_ORG_TOOLS=50
MAX_CUSTOM_TOOL_CALLS_PER_RUN=5

ORG_TOOL_ENCRYPTION_KEY=         # [OPTIONAL] Fernet key for auth headers. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORG_TOOLS_CACHE_TTL_SECONDS=60

LLM_CONFIG_ENCRYPTION_KEY=       # [OPTIONAL] Separate Fernet key for BYOK LLM keys. Falls back to ORG_TOOL_ENCRYPTION_KEY if empty.

# ────────────────────────────────────────────────────────────────────────────────
# ─── MCP Client (per-org external MCP servers) ────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

MAX_ORG_MCP_SERVERS=5
MAX_MCP_TOOLS_PER_SERVER=50
MCP_CLIENT_CONNECT_TIMEOUT_SECONDS=10
MCP_CLIENT_TOOL_CACHE_TTL_SECONDS=300

# ────────────────────────────────────────────────────────────────────────────────
# ─── Marketplace (paid MCP tool hosting + author revenue share) ──────────────────
# ────────────────────────────────────────────────────────────────────────────────

MARKETPLACE_ENABLED=false
MARKETPLACE_DEFAULT_REVENUE_SHARE_BPS=7000  # 7000 = 70%
MARKETPLACE_MINIMUM_WITHDRAWAL_USDC=100000  # $0.10 in atomic units
MARKETPLACE_WITHDRAWAL_COOLDOWN_SECONDS=3600
MARKETPLACE_SETTLEMENT_CDP_ACCOUNT=td-marketplace
MARKETPLACE_SETTLEMENT_CHAIN_ID=84532       # 84532=Base Sepolia, 8453=Base mainnet
MARKETPLACE_AUTO_SWEEP_ENABLED=false
MARKETPLACE_SWEEP_INTERVAL_SECONDS=86400    # 24 hours

# ────────────────────────────────────────────────────────────────────────────────
# ─── x402 Billing (on-chain payments) ──────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

BILLING_ENABLED=false

# If BILLING_ENABLED=true:
X402_PAY_TO_ADDRESS=             # [REQUIRED IF BILLING_ENABLED] Treasury wallet, checksummed EIP-55
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532        # Base Sepolia for dev; use eip155:8453 for mainnet
X402_SCHEME=exact                # exact (flat per-run) | upto (usage-based)
X402_RUN_PRICE=$0.01             # Flat price per /agent/run (fallback if pricing_rules DB table is empty)
X402_UPTO_MAX_AMOUNT=$0.50       # Max per-run amount advertised in upto scheme

BYOK_PLATFORM_FEE_USDC=1000     # Flat platform fee per run for BYOK orgs (1000 = $0.001). Set to 0 to disable.

X402_TREASURY_PRIVATE_KEY=       # [REQUIRED IF A2A_DELEGATION_BILLING_ENABLED] Hex-encoded private key for platform treasury

PRICING_CACHE_TTL_SECONDS=300    # How long to cache pricing_rules before re-querying
SETTLEMENT_RETRY_INTERVAL_SECONDS=10  # Background worker poll interval for retrying failed settlements
SETTLEMENT_MAX_RETRIES=5

# ────────────────────────────────────────────────────────────────────────────────
# ─── Stripe (prepaid credit top-up) ────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=               # [OPTIONAL] sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=           # [OPTIONAL] whsec_...

BILLABLE_AUTH_METHODS=siwe,client_credentials,email  # Auth methods requiring payment

# ────────────────────────────────────────────────────────────────────────────────
# ─── A2A Delegation (outbound agent-to-agent calls) ───────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

A2A_DELEGATION_ENABLED=false
A2A_DELEGATION_TIMEOUT_SECONDS=120
A2A_DELEGATION_MAX_PER_RUN=3
A2A_DELEGATION_REQUIRE_ALLOWLIST=false
A2A_AGENT_CARD_CACHE_TTL_SECONDS=300

A2A_DELEGATION_BILLING_ENABLED=false
A2A_DELEGATION_PLATFORM_FEE_BPS=500          # 500 = 5%
A2A_DELEGATION_MAX_COST_USDC=100000          # $0.10 in atomic units, global per-delegation cap

# ────────────────────────────────────────────────────────────────────────────────
# ─── Agent Wallets (via Coinbase Developer Platform) ──────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

AGENT_WALLET_ENABLED=false

# If AGENT_WALLET_ENABLED=true:
CDP_API_KEY_ID=                  # [REQUIRED IF AGENT_WALLET_ENABLED] Coinbase Developer Platform API key ID
CDP_API_KEY_SECRET=              # [REQUIRED IF AGENT_WALLET_ENABLED] Coinbase Developer Platform API key secret
CDP_WALLET_SECRET=               # [REQUIRED IF AGENT_WALLET_ENABLED] Coinbase Developer Platform wallet secret

CDP_NETWORK=base-sepolia         # base-sepolia (testnet) | base (mainnet)
AGENT_WALLET_MAX_BALANCE_USDC=100000000  # $100 in atomic units

# ────────────────────────────────────────────────────────────────────────────────
# ─── LLM Configuration & Routing ───────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

ALLOW_PRIVATE_LLM_ENDPOINTS=false  # Allow LLM api_base URLs pointing to private IPs (for self-hosted)

DEFAULT_MODEL_POOL=               # [OPTIONAL] JSON array of {provider, model} dicts for smart routing
                                 # Default: [
                                 #   {"provider": "anthropic", "model": "claude-haiku-4-5-20251001"},
                                 #   {"provider": "openai", "model": "gpt-4o-mini"},
                                 #   {"provider": "google", "model": "gemini-2.0-flash"}
                                 # ]

# ────────────────────────────────────────────────────────────────────────────────
# ─── LangSmith Observability ───────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────────────

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=               # [OPTIONAL] https://smith.langchain.com/
LANGSMITH_PROJECT=teardrop